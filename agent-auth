main() {
  local action="${1:-}"
  local agent
  local subcommand

  case "$action" in
    help|-h|--help|"")
      [[ $# -le 1 ]] || fail "unexpected arguments for help"
      usage
      return 0
      ;;
    agents)
      shift
      [[ $# -eq 0 ]] || fail "unexpected arguments for agents"
      list_agents
      return 0
      ;;
  esac

  agent="$1"
  shift
  validate_agent "$agent"

  if [[ "$agent" == "codex" ]]; then
    migrate_legacy_codex_storage_if_needed
  fi

  subcommand="${1:-help}"

  case "$subcommand" in
    help|-h|--help)
      shift
      [[ $# -eq 0 ]] || fail "unexpected arguments for $agent help"
      usage_for_agent "$agent"
      ;;
    list)
      shift
      [[ $# -eq 0 ]] || fail "unexpected arguments for $agent list"
      list_providers "$agent"
      ;;
    status)
      shift
      [[ $# -eq 0 ]] || fail "unexpected arguments for $agent status"
      print_status "$agent"
      ;;
    sessions|session)
      shift
      [[ "$agent" == "codex" ]] || fail "command is only supported for codex: $agent $subcommand"
      codex_sessions "$@"
      ;;
    official)
      shift
      [[ $# -eq 0 ]] || fail "unexpected arguments for $agent official"
      switch_to_official "$agent"
      ;;
    use)
      shift
      [[ $# -ge 1 ]] || fail "provider_id is required for $agent use"
      local provider_id="$1"
      shift
      [[ $# -eq 0 ]] || fail "unexpected arguments for $agent use"
      reset_change_logs
      activate_provider "$agent" "$provider_id"
      ;;
    add)
      shift
      [[ $# -ge 1 ]] || fail "provider_id is required for $agent add"
      local add_provider_id="$1"
      shift
      add_provider "$agent" "$add_provider_id" "$@"
      ;;
    update)
      shift
      [[ $# -ge 1 ]] || fail "provider_id is required for $agent update"
      local update_provider_id="$1"
      shift
      update_provider "$agent" "$update_provider_id" "$@"
      ;;
    delete|remove|rm)
      shift
      [[ $# -ge 1 ]] || fail "provider_id is required for $agent delete"
      local delete_provider_id="$1"
      shift
      [[ $# -eq 0 ]] || fail "unexpected arguments for $agent delete"
      delete_provider "$agent" "$delete_provider_id"
      ;;
    *)
      fail "unknown command for $agent: $subcommand"
      ;;
  esac
}

main "$@"
