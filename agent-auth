add_provider() {
  local agent="$1"
  local provider_id="$2"
  shift 2

  validate_provider_id "$provider_id"

  local name="$provider_id"
  local base_url=""
  local api_key=""
  local model=""
  local entry key value
  local -a env_entries=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --name)
        [[ $# -ge 2 ]] || fail "missing value for --name"
        name="$2"
        shift 2
        ;;
      --url|--base-url)
        [[ $# -ge 2 ]] || fail "missing value for --url"
        base_url="$2"
        shift 2
        ;;
      --key|--api-key)
        [[ $# -ge 2 ]] || fail "missing value for --key"
        api_key="$2"
        shift 2
        ;;
      --model)
        [[ $# -ge 2 ]] || fail "missing value for --model"
        model="$2"
        shift 2
        ;;
      --env)
        [[ $# -ge 2 ]] || fail "missing value for --env"
        entry="$2"
        [[ "$entry" == *=* ]] || fail "--env expects KEY=VALUE"
        key="${entry%%=*}"
        value="${entry#*=}"
        [[ -n "$key" ]] || fail "--env expects non-empty KEY"
        env_entries+=("$key=$value")
        shift 2
        ;;
      --unset-env)
        fail "--unset-env is only supported by update"
        ;;
      *)
        fail "unknown option for add: $1"
        ;;
    esac
  done

  [[ -n "$base_url" ]] || fail "--url is required"
  [[ -n "$api_key" ]] || fail "--key is required"

  reset_change_logs
  write_provider_file "$agent" "$provider_id" "$name" "$base_url" "$api_key" "$model" "${env_entries[@]}"
  activate_provider "$agent" "$provider_id" "Add provider"
}

update_provider() {
  local agent="$1"
  local provider_id="$2"
  shift 2

  validate_provider_id "$provider_id"

  local provider_file
  provider_file="$(provider_file_for "$agent" "$provider_id")"
  require_file "$provider_file"

  local current_name current_base_url current_api_key current_model
  current_name="$(provider_value "$provider_file" "name")"
  current_base_url="$(provider_value "$provider_file" "base_url" 2>/dev/null || true)"
  current_api_key="$(provider_value "$provider_file" "api_key" 2>/dev/null || true)"
  current_model="$(provider_value "$provider_file" "model" 2>/dev/null || true)"

  local name="$current_name"
  local base_url="$current_base_url"
  local api_key="$current_api_key"
  local model="$current_model"
  local entry key value
  local -a add_env_entries=()
  local -a unset_env_keys=()
  local -a current_env_entries=()
  local -a env_entries=()

  while IFS= read -r entry; do
    [[ -n "$entry" ]] || continue
    current_env_entries+=("$entry")
  done < <(provider_env_entries "$provider_file")

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --name)
        [[ $# -ge 2 ]] || fail "missing value for --name"
        name="$2"
        shift 2
        ;;
      --url|--base-url)
        [[ $# -ge 2 ]] || fail "missing value for --url"
        base_url="$2"
        shift 2
        ;;
      --key|--api-key)
        [[ $# -ge 2 ]] || fail "missing value for --key"
        api_key="$2"
        shift 2
        ;;
      --model)
        [[ $# -ge 2 ]] || fail "missing value for --model"
        model="$2"
        shift 2
        ;;
      --env)
        [[ $# -ge 2 ]] || fail "missing value for --env"
        entry="$2"
        [[ "$entry" == *=* ]] || fail "--env expects KEY=VALUE"
        key="${entry%%=*}"
        value="${entry#*=}"
        [[ -n "$key" ]] || fail "--env expects non-empty KEY"
        add_env_entries+=("$key=$value")
        shift 2
        ;;
      --unset-env)
        [[ $# -ge 2 ]] || fail "missing value for --unset-env"
        unset_env_keys+=("$2")
        shift 2
        ;;
      *)
        fail "unknown option for update: $1"
        ;;
    esac
  done

  while IFS= read -r entry; do
    [[ -n "$entry" ]] || continue
    env_entries+=("$entry")
  done < <(merged_env_entries_for_update "$provider_file" "${add_env_entries[@]}" "__UNSET_BOUNDARY__" "${unset_env_keys[@]}")

  local current_env_serialized new_env_serialized
  current_env_serialized="$(printf '%s\n' "${current_env_entries[@]}")"
  new_env_serialized="$(printf '%s\n' "${env_entries[@]}")"

  if [[ "$name" == "$current_name" && "$base_url" == "$current_base_url" && "$api_key" == "$current_api_key" && "$model" == "$current_model" && "$current_env_serialized" == "$new_env_serialized" ]]; then
    fail "no provider fields changed for $agent/$provider_id"
  fi

  reset_change_logs
  write_provider_file "$agent" "$provider_id" "$name" "$base_url" "$api_key" "$model" "${env_entries[@]}"

  if [[ "$(state_value "$agent" "provider_id" 2>/dev/null || true)" == "$provider_id" ]]; then
    activate_provider "$agent" "$provider_id" "Update provider"
    return 0
  fi

  print_provider_header "Update provider" "$agent" "$provider_id" "$name" "$base_url" "$model"
  print_change_logs
  print_block_title "Result"
  print_kv "agent" "$agent"
  print_kv "active" "no"
  print_kv "stored" "yes"
}

delete_provider() {
  local agent="$1"
  local provider_id="$2"

  validate_provider_id "$provider_id"

  local provider_file
  provider_file="$(provider_file_for "$agent" "$provider_id")"
  require_file "$provider_file"

  local active_provider
  active_provider="$(state_value "$agent" "provider_id" 2>/dev/null || true)"

  reset_change_logs

  if [[ "$active_provider" == "$provider_id" ]]; then
    switch_to_official "$agent" >/dev/null
    reset_change_logs
  fi

  rm -f "$provider_file"
  log_note "provider" "deleted: $provider_file"

  if [[ "$agent" == "codex" ]]; then
    remove_legacy_codex_provider_if_present "$provider_id"
    require_writable_path "$CODEX_CONFIG_FILE" "codex config"
    remove_codex_provider_section "$provider_id"
  fi

  local was_active="no"
  if [[ "$active_provider" == "$provider_id" ]]; then
    was_active="yes"
  fi

  local runtime_mode
  runtime_mode="$(state_value "$agent" "mode" 2>/dev/null || echo "unknown")"

  print_block_title "Delete provider: ${agent}/${provider_id}"
  print_change_logs
  print_block_title "Result"
  print_kv "agent" "$agent"
  print_kv "provider_id" "$provider_id"
  print_kv "deleted" "yes"
  print_kv "was_active" "$was_active"
  print_kv "state_mode" "$runtime_mode"
}

list_providers() {
  local agent="$1"
  ensure_agent_layout "$agent"

  local files=("$(provider_dir_for "$agent")"/*.json(N))
  if [[ ${#files[@]} -eq 0 ]]; then
    print_block_title "Providers: $agent"
    echo "(none)"
    return 0
  fi

  ruby -rjson -e '
    agent = ARGV.shift
    headers = ["PROVIDER_ID", "NAME", "BASE_URL", "MODEL", "ENV_KEYS", "UPDATED_AT"]
    rows = ARGV.sort.map do |path|
      data = JSON.parse(File.read(path))
      env_keys = data["env"].is_a?(Hash) ? data["env"].keys.sort.join(",") : "-"
      env_keys = "-" if env_keys.empty?
      [
        data["provider_id"].to_s,
        data["name"].to_s.empty? ? "-" : data["name"].to_s,
        data["base_url"].to_s.empty? ? "-" : data["base_url"].to_s,
        data["model"].to_s.empty? ? "-" : data["model"].to_s,
        env_keys,
        data["updated_at"].to_s.empty? ? "-" : data["updated_at"].to_s
      ]
    end

    widths = headers.each_index.map do |index|
      ([headers[index].length] + rows.map { |row| row[index].length }).max
    end
    format_line = widths.map { |width| "%-#{width}s" }.join("  ")

    puts
    puts "Providers: #{agent}"
    puts(format_line % headers)
    puts(widths.map { |width| "-" * width }.join("  "))
    rows.each do |row|
      puts(format_line % row)
    end
  ' "$agent" "${files[@]}"
}

