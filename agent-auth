sync_claude_provider() {
  local provider_id="$1"
  local provider_file

  provider_file="$(provider_file_for claude "$provider_id")"
  require_file "$provider_file"

  mkdir -p "$CLAUDE_DIR"
  require_writable_path "$CLAUDE_SETTINGS_FILE" "claude settings"
  [[ -f "$(official_backup_for claude)" ]] || require_writable_path "$(official_backup_for claude)" "claude official backup"

  local backup
  backup="$(official_backup_for claude)"
  if [[ -f "$CLAUDE_SETTINGS_FILE" && ! -f "$backup" ]]; then
    mkdir -p "${backup:h}"
    cp "$CLAUDE_SETTINGS_FILE" "$backup"
    chmod 600 "$backup" 2>/dev/null || true
    log_note "backup" "created: $backup"
  fi

  ruby -rjson -e '
    settings_path = ARGV[0]
    provider_path = ARGV[1]
    provider = JSON.parse(File.read(provider_path))
    settings = if File.exist?(settings_path) && !File.zero?(settings_path)
      JSON.parse(File.read(settings_path))
    else
      {}
    end
    settings = {} unless settings.is_a?(Hash)

    env = settings["env"].is_a?(Hash) ? settings["env"] : {}
    env.reject! { |key, _| key.match?(/\A(ANTHROPIC_|CLAUDE_CODE_)/) }

    managed = {}
    managed["ANTHROPIC_BASE_URL"] = provider["base_url"] if provider["base_url"].is_a?(String) && !provider["base_url"].empty?
    managed["ANTHROPIC_AUTH_TOKEN"] = provider["api_key"] if provider["api_key"].is_a?(String) && !provider["api_key"].empty?
    managed["CLAUDE_CODE_ATTRIBUTION_HEADER"] = "0"
    managed["CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC"] = "1"
    managed["CLAUDE_CODE_DISABLE_TERMINAL_TITLE"] = "1"

    extra_env = provider["env"].is_a?(Hash) ? provider["env"] : {}
    extra_env.each { |key, value| managed[key] = value.to_s }

    env.merge!(managed)
    settings["env"] = env
    File.write(settings_path, JSON.pretty_generate(settings) + "\n")
  ' "$CLAUDE_SETTINGS_FILE" "$provider_file"

  chmod 600 "$CLAUDE_SETTINGS_FILE" 2>/dev/null || true
  log_note "settings" "rendered: $CLAUDE_SETTINGS_FILE"
  write_state_file "claude" "$provider_id" "$provider_id"
}

switch_claude_to_official() {
  mkdir -p "$CLAUDE_DIR"
  require_writable_path "$CLAUDE_SETTINGS_FILE" "claude settings"
  [[ -f "$(official_backup_for claude)" ]] || require_writable_path "$(official_backup_for claude)" "claude official backup"

  local backup
  backup="$(official_backup_for claude)"

  if [[ -f "$backup" ]]; then
    cp "$backup" "$CLAUDE_SETTINGS_FILE"
    chmod 600 "$CLAUDE_SETTINGS_FILE" 2>/dev/null || true
    log_note "official" "restored: $backup"
  else
    ruby -rjson -e '
      path = ARGV[0]
      settings = if File.exist?(path) && !File.zero?(path)
        JSON.parse(File.read(path))
      else
        {}
      end
      settings = {} unless settings.is_a?(Hash)
      env = settings["env"].is_a?(Hash) ? settings["env"] : {}
      env.reject! { |key, _| key.match?(/\A(ANTHROPIC_|CLAUDE_CODE_)/) }
      if env.empty?
        settings.delete("env")
      else
        settings["env"] = env
      end
      File.write(path, JSON.pretty_generate(settings) + "\n")
    ' "$CLAUDE_SETTINGS_FILE"
    chmod 600 "$CLAUDE_SETTINGS_FILE" 2>/dev/null || true
    log_note "official" "cleared managed env: $CLAUDE_SETTINGS_FILE"
  fi

  write_state_file "claude" "official" ""
}

sync_gemini_provider() {
