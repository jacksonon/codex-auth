  require_file "$provider_file"

  mkdir -p "$GEMINI_DIR"
  require_writable_path "$GEMINI_ENV_FILE" "gemini env file"
  [[ -f "$(official_backup_for gemini)" ]] || require_writable_path "$(official_backup_for gemini)" "gemini official backup"

  local backup
  backup="$(official_backup_for gemini)"
  if [[ -f "$GEMINI_ENV_FILE" && ! -f "$backup" ]]; then
    mkdir -p "${backup:h}"
    cp "$GEMINI_ENV_FILE" "$backup"
    chmod 600 "$backup" 2>/dev/null || true
    log_note "backup" "created: $backup"
  fi

  ruby -rjson -e '
    env_path = ARGV[0]
    provider_path = ARGV[1]
    provider = JSON.parse(File.read(provider_path))

    env = {}
    if File.exist?(env_path)
      File.foreach(env_path) do |line|
        text = line.strip
        next if text.empty? || text.start_with?("#")
        key, value = text.split("=", 2)
        next if key.nil? || key.empty? || value.nil?
        env[key] = value
      end
    end

    env.reject! { |key, _| key.match?(/\A(?:GOOGLE_GEMINI_|GEMINI_)/) }

    managed = {}
    managed["GOOGLE_GEMINI_BASE_URL"] = provider["base_url"] if provider["base_url"].is_a?(String) && !provider["base_url"].empty?
    managed["GEMINI_API_KEY"] = provider["api_key"] if provider["api_key"].is_a?(String) && !provider["api_key"].empty?

    extra_env = provider["env"].is_a?(Hash) ? provider["env"] : {}
    extra_env.each { |key, value| managed[key] = value.to_s }

    env.merge!(managed)

    body = env.keys.sort.map { |key| "#{key}=#{env[key]}" }.join("\n")
    body << "\n" unless body.empty?
    File.write(env_path, body)
  ' "$GEMINI_ENV_FILE" "$provider_file"

  chmod 600 "$GEMINI_ENV_FILE" 2>/dev/null || true
  log_note "env" "rendered: $GEMINI_ENV_FILE"
  write_state_file "gemini" "$provider_id" "$provider_id"
}

switch_gemini_to_official() {
