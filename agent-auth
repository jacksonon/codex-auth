#!/bin/zsh

set -euo pipefail

SCRIPT_DIR="${0:A:h}"

AGENT_AUTH_DIR="${AGENT_AUTH_DIR:-$HOME/.agent-auth}"
LEGACY_CODEX_AUTH_DIR="${LEGACY_CODEX_AUTH_DIR:-$HOME/.codex-auth}"

PROVIDERS_ROOT="$AGENT_AUTH_DIR/providers"
STATE_DIR="$AGENT_AUTH_DIR/state"
MIGRATIONS_DIR="$AGENT_AUTH_DIR/migrations"

CODEX_DIR="${CODEX_DIR:-$HOME/.codex}"
CODEX_CONFIG_FILE="$CODEX_DIR/config.toml"
CODEX_AUTH_FILE="$CODEX_DIR/auth.json"

CLAUDE_DIR="${CLAUDE_DIR:-$HOME/.claude}"
CLAUDE_SETTINGS_FILE="$CLAUDE_DIR/settings.json"

GEMINI_DIR="${GEMINI_DIR:-$HOME/.gemini}"
GEMINI_ENV_FILE="$GEMINI_DIR/.env"

DEFAULT_PACKY_BASE_URL="https://codex-api-slb.packycode.com/v1"
DEFAULT_WIRE_API="responses"
SUPPORTED_AGENTS=(codex claude gemini)

typeset -ga CHANGE_LOGS=()

usage() {
  cat <<'EOF'
Usage:
  agent-auth help
  agent-auth agents

  agent-auth <agent> help
  agent-auth <agent> list
  agent-auth <agent> status
  agent-auth <agent> official
  agent-auth <agent> use <provider_id>
  agent-auth <agent> add <provider_id> --url <base_url> --key <api_key> [--name <display_name>] [--model <model>] [--env KEY=VALUE ...]
  agent-auth <agent> update <provider_id> [--name <display_name>] [--url <base_url>] [--key <api_key>] [--model <model>] [--env KEY=VALUE ...] [--unset-env KEY ...]
  agent-auth <agent> delete <provider_id>
  agent-auth codex sessions [YYYY|YYYYMM|YYYYMMDD] [--table|--tsv|--json] [--full] [--short-id] [--limit N]

Agents:
  codex   Render provider config into ~/.codex/config.toml + ~/.codex/auth.json
  claude  Render provider env into ~/.claude/settings.json
  gemini  Render provider env into ~/.gemini/.env

Notes:
  - Provider registry is stored under ~/.agent-auth/providers/<agent>/<provider_id>.json
  - agent-auth keeps per-agent state in ~/.agent-auth/state/<agent>.json
  - claude / gemini use common --url and --key flags, then map them to their runtime env names
  - Extra provider-specific env vars can be supplied with repeated --env KEY=VALUE flags
EOF
}

usage_for_agent() {
  local agent="$1"
  cat <<EOF
Usage:
  agent-auth $agent list
  agent-auth $agent status
  agent-auth $agent official
  agent-auth $agent use <provider_id>
  agent-auth $agent add <provider_id> --url <base_url> --key <api_key> [--name <display_name>] [--model <model>] [--env KEY=VALUE ...]
  agent-auth $agent update <provider_id> [--name <display_name>] [--url <base_url>] [--key <api_key>] [--model <model>] [--env KEY=VALUE ...] [--unset-env KEY ...]
  agent-auth $agent delete <provider_id>
EOF

  if [[ "$agent" == "codex" ]]; then
    cat <<'EOF'
  agent-auth codex sessions [YYYY|YYYYMM|YYYYMMDD] [--table|--tsv|--json] [--full] [--short-id] [--limit N]
EOF
  fi
}

fail() {
  echo "Error: $*" >&2
  exit 1
}

print_block_title() {
  local title="$1"
  printf '\n%s\n' "$title"
}

print_kv() {
  local key="$1"
  local value="$2"
  printf '%-18s %s\n' "$key" "$value"
}

reset_change_logs() {
  CHANGE_LOGS=()
}

log_note() {
  local scope="$1"
  local message="$2"
  CHANGE_LOGS+=("${scope}"$'\t'"${message}")
}

print_change_logs() {
  local entry scope message

  [[ ${#CHANGE_LOGS[@]} -gt 0 ]] || return 0

  print_block_title "Changes"
  for entry in "${CHANGE_LOGS[@]}"; do
    scope="${entry%%$'\t'*}"
    message="${entry#*$'\t'}"
    print_kv "$scope" "$message"
  done
}

print_provider_header() {
  local title="$1"
  local agent="$2"
  local provider_id="$3"
  local provider_name="$4"
  local base_url="${5:-}"
  local model="${6:-}"

  print_block_title "${title}: ${agent}/${provider_id}"
  print_kv "agent" "$agent"
  print_kv "provider" "$provider_name"
  if [[ -n "$base_url" ]]; then
    print_kv "base_url" "$base_url"
  fi
  if [[ -n "$model" ]]; then
    print_kv "model" "$model"
  fi
  return 0
}

print_result_summary() {
  local agent="$1"
  local mode="$2"
  local auth_kind_value="${3:-n/a}"

  print_block_title "Result"
  print_kv "agent" "$agent"
  print_kv "mode" "$mode"
  print_kv "auth_kind" "$auth_kind_value"
}

describe_file_state() {
  local file="$1"
  if [[ -f "$file" ]]; then
    echo "present: $file"
  else
    echo "missing: $file"
  fi
}

require_file() {
  local file="$1"
  [[ -f "$file" ]] || fail "missing file: $file"
}

nearest_existing_dir() {
  local path="$1"
  local dir="$path"

  if [[ ! -d "$dir" ]]; then
    dir="${dir:h}"
  fi

  while [[ ! -d "$dir" && "$dir" != "/" ]]; do
    dir="${dir:h}"
  done

  echo "$dir"
}

require_writable_path() {
  local path="$1"
  local label="${2:-path}"
  local existing_dir

  if [[ -e "$path" ]]; then
    [[ -w "$path" ]] || fail "cannot write $label: $path (check filesystem permissions or the current Codex sandbox)"
    return 0
  fi

  existing_dir="$(nearest_existing_dir "$path")"
  [[ -w "$existing_dir" ]] || fail "cannot create $label: $path (parent directory is not writable; check filesystem permissions or the current Codex sandbox)"
}

ensure_root_layout() {
  mkdir -p "$AGENT_AUTH_DIR" "$PROVIDERS_ROOT" "$STATE_DIR" "$MIGRATIONS_DIR"
  chmod 700 "$AGENT_AUTH_DIR" "$PROVIDERS_ROOT" "$STATE_DIR" "$MIGRATIONS_DIR" 2>/dev/null || true
}

ensure_agent_layout() {
  local agent="$1"
  ensure_root_layout
  mkdir -p "$(provider_dir_for "$agent")" "$AGENT_AUTH_DIR/$agent/official"
}

validate_agent() {
  local agent="$1"
  case "$agent" in
    codex|claude|gemini) ;;
    *)
      fail "unsupported agent: $agent"
      ;;
  esac
}

list_agents() {
  print_block_title "Agents"
  printf '%s\n' "${SUPPORTED_AGENTS[@]}"
}

validate_provider_id() {
  local provider_id="$1"
  [[ "$provider_id" =~ ^[A-Za-z0-9][A-Za-z0-9_-]*$ ]] || fail "invalid provider_id: $provider_id"
}

provider_dir_for() {
  local agent="$1"
  echo "$PROVIDERS_ROOT/$agent"
}

provider_file_for() {
  local agent="$1"
  local provider_id="$2"
  echo "$(provider_dir_for "$agent")/$provider_id.json"
}

provider_exists() {
  local agent="$1"
  local provider_id="$2"
  [[ -f "$(provider_file_for "$agent" "$provider_id")" ]]
}

state_file_for() {
  local agent="$1"
  echo "$STATE_DIR/$agent.json"
}

migration_marker_for() {
  local name="$1"
  echo "$MIGRATIONS_DIR/$name.done"
}

official_backup_for() {
  local agent="$1"
  case "$agent" in
    codex)
      echo "$AGENT_AUTH_DIR/$agent/official/auth.json"
      ;;
    claude)
      echo "$AGENT_AUTH_DIR/$agent/official/settings.json"
      ;;
    gemini)
      echo "$AGENT_AUTH_DIR/$agent/official/.env"
      ;;
  esac
}

runtime_target_for() {
  local agent="$1"
  case "$agent" in
    codex)
      echo "$CODEX_CONFIG_FILE + $CODEX_AUTH_FILE"
      ;;
    claude)
      echo "$CLAUDE_SETTINGS_FILE"
      ;;
    gemini)
      echo "$GEMINI_ENV_FILE"
      ;;
  esac
}

files_match() {
  local first="$1"
  local second="$2"
  [[ -f "$first" && -f "$second" ]] || return 1
  cmp -s "$first" "$second"
}

backup_file() {
  local file="$1"
  [[ -f "$file" ]] || return 0
  local backup="${file}.bak"
  [[ -f "$backup" ]] && return 0
  cp "$file" "$backup"
  log_note "backup" "created: $backup"
}

copy_if_different() {
  local source="$1"
  local destination="$2"
  mkdir -p "${destination:h}"
  if files_match "$source" "$destination"; then
    return 0
  fi
  cp "$source" "$destination"
  chmod 600 "$destination" 2>/dev/null || true
  log_note "sync" "updated: $destination"
}

auth_kind() {
  local file="$1"
  ruby -rjson -e '
    path = ARGV[0]
    begin
      data = JSON.parse(File.read(path))
    rescue JSON::ParserError
      puts "invalid"
      exit
    end

    if data.is_a?(Hash) && data.keys.sort == ["OPENAI_API_KEY"]
      puts "api_key"
    elsif data.is_a?(Hash)
      puts "official"
    else
      puts "unknown"
    end
  ' "$file"
}

provider_value() {
  local file="$1"
  local key="$2"
  ruby -rjson -e '
    data = JSON.parse(File.read(ARGV[0]))
    value = data[ARGV[1]]

    case value
    when nil
      exit 1
    when TrueClass, FalseClass
      puts(value ? "true" : "false")
    else
      puts value
    end
  ' "$file" "$key"
}

provider_env_entries() {
  local file="$1"
  ruby -rjson -e '
    data = JSON.parse(File.read(ARGV[0]))
    env = data["env"].is_a?(Hash) ? data["env"] : {}
    env.keys.sort.each do |key|
      puts "#{key}=#{env[key]}"
    end
  ' "$file"
}

merged_env_entries_for_update() {
  local file="$1"
  shift

  ruby -rjson -e '
    provider = JSON.parse(File.read(ARGV[0]))
    env = provider["env"].is_a?(Hash) ? provider["env"] : {}
    mode = :add

    ARGV[1..].each do |arg|
      if arg == "__UNSET_BOUNDARY__"
        mode = :unset
        next
      end

      if mode == :add
        key, value = arg.split("=", 2)
        next if key.nil? || key.empty? || value.nil?
        env[key] = value
      else
        env.delete(arg)
      end
    end

    env.keys.sort.each do |key|
      puts "#{key}=#{env[key]}"
    end
  ' "$file" "$@" 
}

provider_env_keys_csv() {
  local file="$1"
  ruby -rjson -e '
    data = JSON.parse(File.read(ARGV[0]))
    env = data["env"].is_a?(Hash) ? data["env"] : {}
    puts env.keys.sort.join(",")
  ' "$file"
}

write_state_file() {
  local agent="$1"
  local mode="$2"
  local provider_id="${3:-}"

  ensure_root_layout
  require_writable_path "$(state_file_for "$agent")" "state file"

  ruby -rjson -rtime -e '
    path = ARGV[0]
    agent = ARGV[1]
    mode = ARGV[2]
    provider_id = ARGV[3]
    payload = {
      "schema_version" => 1,
      "agent" => agent,
      "mode" => mode,
      "updated_at" => Time.now.utc.iso8601
    }
    payload["provider_id"] = provider_id unless provider_id.nil? || provider_id.empty?
    File.write(path, JSON.pretty_generate(payload) + "\n")
  ' "$(state_file_for "$agent")" "$agent" "$mode" "$provider_id"

  chmod 600 "$(state_file_for "$agent")" 2>/dev/null || true
  log_note "state" "updated: $(state_file_for "$agent")"
}

state_value() {
  local agent="$1"
  local key="$2"
  local file
  file="$(state_file_for "$agent")"
  [[ -f "$file" ]] || return 1

  ruby -rjson -e '
    data = JSON.parse(File.read(ARGV[0]))
    value = data[ARGV[1]]
    exit 1 if value.nil?
    puts value
  ' "$file" "$key"
}

migrate_legacy_codex_storage_if_needed() {
  ensure_agent_layout "codex"

  local marker
  marker="$(migration_marker_for "codex_legacy_storage_v1")"

  if [[ -f "$marker" ]]; then
    return 0
  fi

  [[ -d "$LEGACY_CODEX_AUTH_DIR" ]] || return 0

  local legacy_official="$LEGACY_CODEX_AUTH_DIR/openai/auth.json"
  local new_official
  new_official="$(official_backup_for codex)"

  if [[ -f "$legacy_official" && ! -f "$new_official" ]]; then
    mkdir -p "${new_official:h}"
    cp "$legacy_official" "$new_official"
    chmod 600 "$new_official" 2>/dev/null || true
  fi

  local legacy_files=("$LEGACY_CODEX_AUTH_DIR"/providers/*.json(N))
  local legacy_file
  local provider_id
  local target_file

  for legacy_file in "${legacy_files[@]}"; do
    provider_id="${${legacy_file:t}%.json}"
    target_file="$(provider_file_for codex "$provider_id")"
    [[ -f "$target_file" ]] && continue

    ruby -rjson -rtime -e '
      source = ARGV[0]
      target = ARGV[1]
      provider_id = ARGV[2]
      payload = JSON.parse(File.read(source))
      out = {
        "schema_version" => 2,
        "agent" => "codex",
        "provider_id" => provider_id,
        "name" => payload["name"].to_s.empty? ? provider_id : payload["name"],
        "base_url" => payload["base_url"],
        "api_key" => payload["api_key"],
        "model" => payload["model"],
        "wire_api" => payload["wire_api"] || "responses",
        "requires_openai_auth" => payload.key?("requires_openai_auth") ? payload["requires_openai_auth"] : true,
        "env" => payload["env"].is_a?(Hash) ? payload["env"] : {},
        "updated_at" => payload["updated_at"] || Time.now.utc.iso8601
      }.reject { |_, value| value.nil? || value == "" || value == {} }
      File.write(target, JSON.pretty_generate(out) + "\n")
    ' "$legacy_file" "$target_file" "$provider_id"
    chmod 600 "$target_file" 2>/dev/null || true
  done

  : > "$marker"
  chmod 600 "$marker" 2>/dev/null || true
}

remove_legacy_codex_provider_if_present() {
  local provider_id="$1"
  local legacy_provider_file="$LEGACY_CODEX_AUTH_DIR/providers/$provider_id.json"

  [[ -f "$legacy_provider_file" ]] || return 0

  rm -f "$legacy_provider_file"
  log_note "legacy provider" "deleted: $legacy_provider_file"
}

write_provider_file() {
  local agent="$1"
  local provider_id="$2"
  local name="$3"
  local base_url="$4"
  local api_key="$5"
  local model="$6"
  shift 6
  local env_entries=("$@")
  local file

  file="$(provider_file_for "$agent" "$provider_id")"
  ensure_agent_layout "$agent"
  require_writable_path "$file" "provider file"

  ruby -rjson -rtime -e '
    path = ARGV[0]
    agent = ARGV[1]
    provider_id = ARGV[2]
    name = ARGV[3]
    base_url = ARGV[4]
    api_key = ARGV[5]
    model = ARGV[6]
    env_entries = ARGV[7..] || []

    env = {}
    env_entries.each do |entry|
      key, value = entry.split("=", 2)
      next if key.nil? || key.empty? || value.nil?
      env[key] = value
    end

    payload = {
      "schema_version" => 2,
      "agent" => agent,
      "provider_id" => provider_id,
      "name" => name,
      "updated_at" => Time.now.utc.iso8601
    }

    payload["base_url"] = base_url unless base_url.nil? || base_url.empty?
    payload["api_key"] = api_key unless api_key.nil? || api_key.empty?
    payload["model"] = model unless model.nil? || model.empty?
    payload["env"] = env unless env.empty?

    if agent == "codex"
      payload["wire_api"] = "responses"
      payload["requires_openai_auth"] = true
    end

    File.write(path, JSON.pretty_generate(payload) + "\n")
  ' "$file" "$agent" "$provider_id" "$name" "$base_url" "$api_key" "$model" "${env_entries[@]}"

  chmod 600 "$file"
  log_note "provider" "saved: $file"
}

upsert_or_remove_top_level_string() {
  local file_path="$1"
  local key="$2"
  local value="$3"

  ruby -e '
    path = ARGV[0]
    key = ARGV[1]
    value = ARGV[2]
    lines = File.exist?(path) ? File.read(path).lines : []
    pattern = /^\s*#?\s*#{Regexp.escape(key)}\s*=/
    replacement = value.empty? ? nil : "#{key} = \"#{value}\"\n"
    replaced = false
    result = []

    lines.each do |line|
      if line.match?(pattern)
        unless replaced
          result << replacement if replacement
          replaced = true
        end
      else
        result << line
      end
    end

    result.unshift(replacement) if replacement && !replaced
    File.write(path, result.join)
  ' "$file_path" "$key" "$value"

  if [[ -n "$value" ]]; then
    log_note "config" "$key = $value"
  else
    log_note "config" "$key removed"
  fi
}

set_codex_mode_specific_config() {
  local mode="$1"

  ruby -e '
    path = ARGV[0]
    mode = ARGV[1]
    lines = File.read(path).lines

    def upsert_top_level(lines, key, new_line)
      pattern = /^\s*#?\s*#{Regexp.escape(key)}\s*=/
      replaced = false
      result = []

      lines.each do |line|
        if line.match?(pattern)
          unless replaced
            result << new_line
            replaced = true
          end
        else
          result << line
        end
      end

      result.unshift(new_line) unless replaced
      result
    end

    web_search_line = mode == "provider" ? "web_search = \"live\"\n" : "#web_search = \"live\"\n"
    context_window_line = "model_context_window = 256000\n"
    compact_line = "#model_auto_compact_token_limit = 900000\n"
    status_items = [
      "model-with-reasoning",
      "fast-mode",
      "context-window-size",
      "context-used",
      "context-remaining",
      "used-tokens",
      "total-input-tokens",
      "total-output-tokens",
      "git-branch"
    ]
    status_items += ["five-hour-limit", "weekly-limit"] if mode == "official"
    status_line = "status_line = [#{status_items.map { |item| "\"#{item}\"" }.join(", ")}]\n"

    lines = upsert_top_level(lines, "web_search", web_search_line)
    lines = upsert_top_level(lines, "model_context_window", context_window_line)
    lines = upsert_top_level(lines, "model_auto_compact_token_limit", compact_line)

    tui_start = lines.index { |line| line.match?(/^\s*\[tui\]\s*$/) }

    if tui_start.nil?
      lines << "\n" unless lines.empty? || lines.last == "\n"
      lines << "[tui]\n"
      lines << status_line
    else
      tui_end = lines[(tui_start + 1)..].index { |line| line.match?(/^\s*\[[^\]]+\]\s*$/) }
      tui_end = tui_end.nil? ? lines.length : tui_start + 1 + tui_end
      replaced = false
      result = []

      lines.each_with_index do |line, idx|
        if idx > tui_start && idx < tui_end && line.match?(/^\s*status_line\s*=/)
          unless replaced
            result << status_line
            replaced = true
          end
        else
          result << line
        end
      end

      unless replaced
        insert_at = result.length
        result.each_with_index do |line, idx|
          if idx > tui_start && line.match?(/^\s*\[[^\]]+\]\s*$/)
            insert_at = idx
            break
          end
        end
        result.insert(insert_at, status_line)
      end

      lines = result
    end

    File.write(path, lines.join)
  ' "$CODEX_CONFIG_FILE" "$mode"

  log_note "config" "mode settings applied: $mode"
}

set_codex_active_provider() {
  local provider_id="$1"
  local mode="$2"

  ruby -e '
    path = ARGV[0]
    provider_id = ARGV[1]
    mode = ARGV[2]
    lines = File.read(path).lines
    pattern = /^\s*#?\s*model_provider\s*=/
    replacement = mode == "official" ? nil : "model_provider = \"#{provider_id}\"\n"
    replaced = false
    result = []

    lines.each do |line|
      if line.match?(pattern)
        unless replaced
          result << replacement if replacement
          replaced = true
        end
      else
        result << line
      end
    end

    result.unshift(replacement) if replacement && !replaced
    File.write(path, result.join)
  ' "$CODEX_CONFIG_FILE" "$provider_id" "$mode"

  if [[ "$mode" == "official" ]]; then
    log_note "config" "model_provider disabled"
  else
    log_note "config" "model_provider = $provider_id"
  fi
}

upsert_codex_provider_section() {
  local provider_id="$1"
  local name="$2"
  local base_url="$3"
  local wire_api="$4"
  local requires_openai_auth="$5"

  ruby -e '
    path = ARGV[0]
    provider_id = ARGV[1]
    name = ARGV[2]
    base_url = ARGV[3]
    wire_api = ARGV[4]
    requires_openai_auth = ARGV[5]
    lines = File.read(path).lines
    header = "[model_providers.#{provider_id}]"
    section = [
      "#{header}\n",
      "name = \"#{name}\"\n",
      "base_url = \"#{base_url}\"\n",
      "wire_api = \"#{wire_api}\"\n",
      "requires_openai_auth = #{requires_openai_auth}\n"
    ]

    start = lines.index { |line| line.strip == header }
    if start.nil?
      lines << "\n" unless lines.empty? || lines.last == "\n"
      lines.concat(section)
    else
      finish = lines[(start + 1)..].index { |line| line.match?(/^\s*\[[^\]]+\]\s*$/) }
      finish = finish.nil? ? lines.length : start + 1 + finish
      lines = lines[0...start] + section + lines[finish..]
    end

    File.write(path, lines.join)
  ' "$CODEX_CONFIG_FILE" "$provider_id" "$name" "$base_url" "$wire_api" "$requires_openai_auth"

  log_note "config" "provider section refreshed: [model_providers.$provider_id]"
}

remove_codex_provider_section() {
  local provider_id="$1"

  [[ -f "$CODEX_CONFIG_FILE" ]] || return 0

  ruby -e '
    path = ARGV[0]
    provider_id = ARGV[1]
    header = "[model_providers.#{provider_id}]"
    lines = File.read(path).lines

    start = lines.index { |line| line.strip == header }
    exit 0 if start.nil?

    finish = lines[(start + 1)..].index { |line| line.match?(/^\s*\[[^\]]+\]\s*$/) }
    finish = finish.nil? ? lines.length : start + 1 + finish
    lines = lines[0...start] + lines[finish..]
    File.write(path, lines.join)
  ' "$CODEX_CONFIG_FILE" "$provider_id"

  log_note "config" "provider section removed: [model_providers.$provider_id]"
}

codex_config_mode() {
  ruby -e '
    text = File.read(ARGV[0])
    if (match = text.match(/^[[:space:]]*model_provider[[:space:]]*=[[:space:]]*"([^"]+)"/))
      puts match[1]
    else
      puts "official"
    end
  ' "$CODEX_CONFIG_FILE"
}

write_codex_auth_file() {
  local api_key="$1"

  ruby -rjson -e '
    path = ARGV[0]
    api_key = ARGV[1]
    File.write(path, JSON.pretty_generate({ "OPENAI_API_KEY" => api_key }) + "\n")
  ' "$CODEX_AUTH_FILE" "$api_key"

  chmod 600 "$CODEX_AUTH_FILE" 2>/dev/null || true
  log_note "auth" "rendered: $CODEX_AUTH_FILE"
}

